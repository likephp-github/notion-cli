    { "id": "US-026", "title": "card archive (with --yes guard, idempotent)", "phase": 2, "passes": true, "acceptanceCriteria": ["--yes required (or NOTION_CLI_FORCE=1)", "idempotent on already-archived"] },
    { "id": "US-027", "title": "Phase 2 verification", "phase": 2, "passes": true, "acceptanceCriteria": ["lint/type/test green", "database alias roundtrip smoke"] },

    { "id": "US-031", "title": "database schema introspection + cache", "phase": 3, "passes": true, "acceptanceCriteria": ["cold/warm/expired/no-cache covered", "summarize_schema extracts options"] },
