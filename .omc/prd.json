  "stories": [
    { "id": "US-001", "title": "Project scaffold + packaging", "phase": 1, "passes": true, "acceptanceCriteria": ["pyproject.toml + entry point", "venv install", "--version 0.1.0", "ruff/mypy clean"] },
    { "id": "US-002", "title": "Output contract + error handling + exit codes", "phase": 1, "passes": true, "acceptanceCriteria": ["emit_ok stdout / emit_error stderr", "CLIError subclasses with exit codes 1/2/3/4"] },
    { "id": "US-003", "title": "Configuration loader (config.toml)", "phase": 1, "passes": true, "acceptanceCriteria": ["XDG load/save/resolve_database covered by tests"] },
    { "id": "US-004", "title": "Credentials store (keyring + chmod-600 fallback)", "phase": 1, "passes": true, "acceptanceCriteria": ["keyring primary, chmod 600 fallback, env override, idempotent delete"] },
    { "id": "US-005", "title": "Notion API client wrapper with retry + token masking", "phase": 1, "passes": true, "acceptanceCriteria": ["get_client raises AuthError when no token", "tenacity retry on transient only (predicate-based)", "log filter masks tokens"] },
    { "id": "US-006", "title": "CLI root app (Typer)", "phase": 1, "passes": true, "acceptanceCriteria": ["--version prints 0.1.0", "--help lists init/logout/auth/database/card/comment/search"] },
    { "id": "US-007", "title": "notion-cli init wizard", "phase": 1, "passes": true, "acceptanceCriteria": ["non-interactive happy path", "ALREADY_CONFIGURED rejection", "--force overwrites", "interactive token prompt via getpass"] },
    { "id": "US-008", "title": "notion-cli logout", "phase": 1, "passes": true, "acceptanceCriteria": ["clears token + config + cache", "--keep-config preserves", "idempotent on empty state"] },
    { "id": "US-009", "title": "notion-cli auth verify + status", "phase": 1, "passes": true, "acceptanceCriteria": ["auth verify lists databases", "auth status reports source without leaking token"] },
    { "id": "US-010", "title": "Phase 1 verification", "phase": 1, "passes": true, "acceptanceCriteria": ["unit tests pass", "ruff clean", "mypy clean", "smoke tests pass"] },

    { "id": "US-021", "title": "database add / ls / rm — alias management", "phase": 2, "passes": true, "acceptanceCriteria": ["add validates UUID, refuses dup without --force", "ls reports default flag", "rm idempotent"] },
    { "id": "US-022", "title": "card list with --filter-json / --sort / --limit / pagination", "phase": 2, "passes": true, "acceptanceCriteria": ["multi-page pagination until limit", "filter-json passthrough", "sort with - prefix"] },
    { "id": "US-023", "title": "card get", "phase": 2, "passes": true, "acceptanceCriteria": ["happy path emits properties", "404 → exit 4 NOT_FOUND"] },
